<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_payslip" model="ir.actions.report">
        <field name="name">Employee Payslip</field>
        <field name="model">payroll.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_payroll.report_payslip_template</field>
        <field name="report_file">custom_payroll.report_payslip_template</field>
        <field name="print_report_name">'Payslip - %s - %s' % (object.employee_id.name, object.name)</field>
        <field name="binding_model_id" ref="model_payroll_payslip"/>
        <field name="binding_type">report</field>
    </record>

</odoo>
