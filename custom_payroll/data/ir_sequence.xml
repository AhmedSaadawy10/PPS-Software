<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_x_payroll_contract" model="ir.sequence">
            <field name="name">Payroll Contract</field>
            <field name="code">x_payroll.contract</field>
            <field name="prefix">CNT</field>
            <field name="padding">7</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_payroll_payslip" model="ir.sequence">
            <field name="name">Employee Payslip Sequence</field>
            <field name="code">payroll.payslip</field>
            <field name="prefix">SLIP</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>