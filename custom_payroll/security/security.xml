<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    <!--Category-->
        <record model="ir.module.category" id="module_category_custom_payroll">
            <field name="name">Custom Payroll</field>
            <field name="sequence">20</field>
        </record>

        <record model="res.groups.privilege" id="res_groups_privilege_custom_payroll">
            <field name="name">Payroll Management</field>
            <field name="category_id" ref="module_category_custom_payroll"/>
        </record>
        <!--groups-->
        <record id="group_payroll_user" model="res.groups">
            <field name="name">Employee</field>
            <field name="privilege_id" ref="res_groups_privilege_custom_payroll"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_payroll_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_custom_payroll"/>
            <field name="implied_ids" eval="[(4, ref('group_payroll_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    <!--===========================Record Rules========================================-->
        <!--payroll contract -->
        <record id="payroll_contract_rule_employee" model="ir.rule">
            <field name="name">Employee: See Own Contracts Only</field>
            <field name="model_id" ref="model_x_payroll_contract"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="payroll_contract_rule_manager" model="ir.rule">
            <field name="name">Manager: See All Contracts</field>
            <field name="model_id" ref="model_x_payroll_contract"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_payroll_manager'))]"/>
        </record>




    </data>
</odoo>