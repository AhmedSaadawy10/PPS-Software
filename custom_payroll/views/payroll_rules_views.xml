<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_payroll_rule_list" model="ir.ui.view">
        <field name="name">payroll.rule.list</field>
        <field name="model">payroll.rule</field>
        <field name="arch" type="xml">
            <list string="Salary Rules">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="amount_type"/>
            </list>
        </field>
    </record>

    <record id="view_payroll_rule_form" model="ir.ui.view">
        <field name="name">payroll.rule.form</field>
        <field name="model">payroll.rule</field>
        <field name="arch" type="xml">
            <form string="Salary Rule">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Basic Salary"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="struct_id"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Calculation Rules" name="calculation_rules">
                            <group>
                                <group string="Amount Configuration">
                                    <field name="amount_type"/>
                                    <field name="amount_fix" invisible="amount_type != 'fixed'"/>
                                    <field name="amount_percentage" invisible="amount_type != 'percentage'"/>
                                    <field name="amount_python_code" invisible="amount_type != 'code'" widget="ace"
                                           options="{'mode': 'python'}"/>
                                </group>
                                <group string="Condition Configuration">
                                    <field name="condition_select"/>
                                    <field name="condition_range_field" invisible="condition_select != 'range'"/>
                                    <field name="condition_range_min" invisible="condition_select != 'range'"/>
                                    <field name="condition_range_max" invisible="condition_select != 'range'"/>
                                    <field name="condition_python_code" invisible="condition_select != 'python'"
                                           widget="ace"
                                           options="{'mode': 'python'}"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_payroll_rule_search" model="ir.ui.view">
        <field name="name">payroll.rule.view.search</field>
        <field name="model">payroll.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Rule Name"/>
                <field name="code" string="Rule Code"/>
                <field name="struct_id" string="Salary Structure"/>

                <separator/>

                <filter name="filter_basic" string="Basic Rules" domain="[('category', '=', 'basic')]"/>
                <filter name="filter_allowance" string="Allowances" domain="[('category', '=', 'allowance')]"/>
                <filter name="filter_deduction" string="Deductions" domain="[('category', '=', 'deduction')]"/>

                <group>
                    <filter name="group_by_struct_id" string="Salary Structure" context="{'group_by': 'struct_id'}"/>
                    <filter name="group_by_category" string="Category" context="{'group_by': 'category'}"/>
                    <filter name="group_by_amount_type" string="Amount Type" context="{'group_by': 'amount_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_payroll_rule" model="ir.actions.act_window">
        <field name="name">Salary Rules</field>
        <field name="res_model">payroll.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_payroll_rule_search"/>
        <field name="context">{'search_default_group_by_struct_id': 1}</field>
    </record>

    <menuitem id="menu_payroll_rule_sub"
              name="Rules"
              parent="menu_payroll_salary_structure"
              action="action_payroll_rule"
              sequence="30"/>

</odoo>