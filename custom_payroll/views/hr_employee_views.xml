<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_inherit_payroll" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.payroll</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_employee_contracts"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-book">
                    <field name="contract_count" widget="statinfo" string="Contracts"/>
                </button>

                <button name="action_view_employee_payslips"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money">
                    <field name="payslip_count" widget="statinfo" string="Payslips"/>
                </button>
            </xpath>

        </field>
    </record>

</odoo>